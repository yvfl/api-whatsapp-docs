{
  "name": "whatsapp-docs-mcp",
  "version": "1.0.0",
  "description": "MCP server for WhatsApp Business API documentation - Access comprehensive WhatsApp Business API docs through Model Context Protocol",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "whatsapp-docs-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "validate": "node scripts/validate-docs.js",
    "prepublishOnly": "npm run validate && npm run build"
  },
  "keywords": [
    "mcp",
    "whatsapp",
    "whatsapp-business-api",
    "api",
    "documentation",
    "claude",
    "cursor",
    "model-context-protocol",
    "ai-assistant"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seu-usuario/api-whatsapp-docs.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0"
  }
}
